# AI-Продажник PRO — опциональные переменные окружения
#
# Без этого файла работают 13 из 15 режимов (только на промпте и config.yaml).
# Заполните только если хотите интеграции с реальными системами.
#
# Как использовать:
# cp .env.example .env
# # откройте .env и заполните нужные ключи
# # ═══════════════════════════════════════════════════
# LLM API — обязателен если работаете вне Claude/OpenClaw
# ═══════════════════════════════════════════════════
# Где брать Anthropic: https://console.anthropic.com/ → API Keys
# Где брать OpenAI: https://platform.openai.com/ → API Keys LLM_API_KEY="" # ANTHROPIC_API_KEY или OPENAI_API_KEY
ANTHROPIC_API_KEY="" # если через Anthropic SDK
OPENAI_API_KEY="" # если через OpenAI-совместимый API # ═══════════════════════════════════════════════════
# Telegram — РОП-бот и рассылка скриптов менеджерам
# ═══════════════════════════════════════════════════
# Где брать бот-токен: @BotFather в Telegram → /newbot
# Где брать chat_id: @userinfobot → переслать боту любое сообщение
# Функции: рассылка pipeline-отчётов, скриптов, уведомлений о red flags TELEGRAM_BOT_TOKEN="" # токен бота РОПа
TELEGRAM_CHAT_ID_ROP="" # chat_id руководителя отдела продаж
TELEGRAM_CHAT_ID_TEAM="" # chat_id группового чата команды продаж # ═══════════════════════════════════════════════════
# Google Sheets — CRM-выгрузки, pipeline, метрики
# ═══════════════════════════════════════════════════
# Где брать: https://console.cloud.google.com/ → Service Account → JSON key
# Гайд: docs/onboarding.md раздел "Google Sheets"
# Функции: выгрузка лидов, pipeline, win/loss статистики GOOGLE_SHEETS_CREDENTIALS_JSON="" # путь к JSON-ключу сервис-аккаунта
GOOGLE_SHEETS_SPREADSHEET_ID="" # ID таблицы (из URL)
GOOGLE_SHEETS_TAB_PIPELINE="Pipeline" # вкладка с pipeline
GOOGLE_SHEETS_TAB_LEADS="Leads" # вкладка с лидами
GOOGLE_SHEETS_TAB_WINLOSS="WinLoss" # вкладка с win/loss аналитикой # ═══════════════════════════════════════════════════
# amoCRM — интеграция для pipeline и сделок
# ═══════════════════════════════════════════════════
# Где брать: amoCRM → Настройки → Интеграции → API
# Функции: создание сделок, обновление статуса, получение аналитики AMOCRM_API_KEY="" # API-ключ amoCRM
AMOCRM_SUBDOMAIN="" # поддомен вашего amoCRM (example.amocrm.ru) # ═══════════════════════════════════════════════════
# Bitrix24 — интеграция для CRM и pipeline
# ═══════════════════════════════════════════════════
# Где брать: Битрикс24 → Разработчикам → Входящие вебхуки BITRIX24_WEBHOOK_URL="" # URL входящего вебхука Битрикс24 # ═══════════════════════════════════════════════════
# Google Calendar — для встреч и follow-up напоминаний
# ═══════════════════════════════════════════════════ GOOGLE_CALENDAR_ID="" # ID календаря продаж # ═══════════════════════════════════════════════════
# Web Search — для разведки конкурентов и анализа рынка
# ═══════════════════════════════════════════════════ EXA_API_KEY="" # Exa.ai для поиска (win/loss + конкуренты)
TAVILY_API_KEY="" # Tavily (альтернатива)
